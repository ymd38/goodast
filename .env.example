# goodast 環境変数サンプル。
#
# 使い方: このファイルを `.env` にコピーして値を埋める（`.env` は .gitignore 済み・コミット禁止）。
#   cp .env.example .env
#
# - docker-compose は同ディレクトリの `.env` を自動読込し、${POSTGRES_*} を補間する。
# - api / worker（Go）は環境変数を直接読む（12-factor / internal/config）。必須変数が欠けると起動失敗。
# - `make dev-api` / `make dev-worker` は DATABASE_URL を Makefile 既定で渡し、暗号鍵は
#   `make dev-key` が生成する `.dev-encryption-key` から注入するため、ローカル開発では
#   GOODAST_ENCRYPTION_KEY を手で設定しなくてもよい（手動起動・compose 運用時に必要）。

# ─────────────────────────────────────────────
# PostgreSQL（docker-compose db サービス / compose の ${...} 補間に使用）
# ─────────────────────────────────────────────
POSTGRES_DB=goodast
POSTGRES_USER=goodast
POSTGRES_PASSWORD=goodast

# ─────────────────────────────────────────────
# 共通（api / worker 両方が読む・必須）
# ─────────────────────────────────────────────
# DB 接続文字列（必須）。
#   ローカル（make dev-* / ホストから接続）: 127.0.0.1:5432
#   docker-compose のコンテナ内から接続する場合はホスト名を db に変える（@db:5432）。
DATABASE_URL=postgres://goodast:goodast@127.0.0.1:5432/goodast?sslmode=disable

# 認証情報（Cookie/Bearer）の暗号鍵（必須・base64 の 32 バイト = AES-256・ADR-0003）。
# api と worker で必ず同一の値を設定する（api が暗号化・worker が復号）。
# 生成: openssl rand -base64 32
# 注意: 本番鍵は絶対にコミットしない。ここは空のままにし、`.env` にのみ実値を書く。
GOODAST_ENCRYPTION_KEY=

# ─────────────────────────────────────────────
# 共通（任意・未設定なら既定値）
# ─────────────────────────────────────────────
# ログレベル: debug / info / warn / error（既定 info）
LOG_LEVEL=info
# グレースフルシャットダウンの猶予（Go duration・既定 30s）
SHUTDOWN_TIMEOUT=30s
# pgxpool 接続数（既定 max=10 / min=2。min <= max・max >= 1）
DB_MAX_CONNS=10
DB_MIN_CONNS=2

# ─────────────────────────────────────────────
# api 固有（任意）
# ─────────────────────────────────────────────
# API サーバの待受アドレス（既定 :8080）
API_ADDR=:8080

# 自己スキャン防止: GOODAST 自身の origin（ドメイン+ポート・CSV）。ここに一致する対象は
# サイト登録できない（既定は web UI :3000 と api :8080）。ループバック別名（127.0.0.1 / ::1）は
# 正規化で localhost に畳み込まれるため同時に覆う。デプロイ先の実際の公開 origin に合わせて上書きする。
GOODAST_SELF_ORIGINS=localhost:3000,localhost:8080

# ─────────────────────────────────────────────
# worker 固有（任意）
# ─────────────────────────────────────────────
# worker のヘルスチェック HTTP 待受アドレス（既定 :9090）
WORKER_HEALTH_ADDR=:9090

# ─────────────────────────────────────────────
# テスト / 検証（integration・任意）
# ─────────────────────────────────────────────
# 結合テスト用 DB（未設定なら DATABASE_URL を使う）
TEST_DATABASE_URL=postgres://goodast:goodast@127.0.0.1:5432/goodast?sslmode=disable
# 検知精度・認証後スキャン検証の対象（make juiceshop-up で起動する Juice Shop）
NUCLEI_TEST_TARGET=http://localhost:3001
# スキャン対象を絞るタグ（CSV・未設定なら misconfig,tech）
NUCLEI_TEST_TAGS=misconfig,tech

# Nuclei テンプレート（固定版）。make nuclei-templates が取得し worker 起動時に版を検証する。
# 注意: NUCLEI_TEMPLATES_DIR は絶対パス推奨（.env 直読み時）。worker は worker/ ディレクトリで
#   起動する（cd worker && go run ./cmd/worker）ため、相対パスだと worker/nuclei-templates を
#   指してしまい、clone が展開したリポジトリ直下のディレクトリと一致しない。
#   `make dev-worker` は Makefile の絶対パス（$(CURDIR)/nuclei-templates）を自動的に渡すため、
#   この注意は worker を直接手動起動する場合にのみ関係する。
NUCLEI_TEMPLATES_DIR=/absolute/path/to/goodast/nuclei-templates
NUCLEI_TEMPLATES_VERSION=v10.4.5
